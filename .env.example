# ============================================================
# Variables d'environnement — Board Game Dashboard
#
# DEV LOCAL  : copier vers backend/.env (lu par Express via dotenv)
# PRODUCTION : copier vers .env à la racine (lu par docker compose)
#
# Ne jamais commiter .env (ignoré par .gitignore).
# ============================================================

# --- Authentification JWT ---
# Secret de signature JWT. OBLIGATOIRE en production.
# Générer : openssl rand -hex 32
AUTH_JWT_SECRET=change-this-to-a-random-secret-min-32-chars

# Mot de passe administrateur (import BGG catalog, features avancées)
ADMIN_PASSWORD=change-this-admin-password

# Mot de passe utilisateur standard (lecture + création sessions)
# Laisser vide pour désactiver le rôle user (admin uniquement)
USER_PASSWORD=change-this-user-password

# --- CORS ---
# Origines autorisées, séparées par des virgules.
# En production : URL publique derrière le reverse proxy (ex: https://games.mondomaine.tld)
CORS_ORIGINS=http://localhost:5173

# --- Logging ---
# Niveaux disponibles : trace, debug, info, warn, error, fatal
LOG_LEVEL=info
