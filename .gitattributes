# Force LF line endings for all text files (project runs on Linux/Docker)
* text=auto eol=lf

# Explicitly LF for source files
*.ts    eol=lf
*.tsx   eol=lf
*.js    eol=lf
*.jsx   eol=lf
*.json  eol=lf
*.md    eol=lf
*.sql   eol=lf
*.css   eol=lf
*.html  eol=lf
*.sh    eol=lf
*.yml   eol=lf
*.yaml  eol=lf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.db    binary
