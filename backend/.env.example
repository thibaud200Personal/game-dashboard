PORT=3001
DB_PATH=/data/board_game_score.db
# In production, replace with your actual domain (e.g. https://yourdomain.com)
CORS_ORIGINS=http://localhost:5000,http://localhost:5173
NODE_ENV=production
# Secret JWT — generate with: openssl rand -hex 32
AUTH_JWT_SECRET=change-this-to-a-random-secret-min-32-chars
ADMIN_PASSWORD=change-this-admin-password
USER_PASSWORD=change-this-user-password
